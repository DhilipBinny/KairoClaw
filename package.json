{
  "name": "agentic-gateway",
  "version": "0.2.0",
  "type": "module",
  "description": "Self-hosted agentic LLM gateway with Telegram + Web UI",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "pnpm -r build",
    "dev:v2": "pnpm --filter @agw/core dev",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "grammy": "^1.35.0",
    "json5": "^2.2.3",
    "openai": "^4.80.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "puppeteer-core": "^24.38.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
