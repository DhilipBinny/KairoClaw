# ══════════════════════════════════════════════════════════
# Kairo — Environment Variables
# ══════════════════════════════════════════════════════════
#
# Quick start:
#   cp .env.example .env
#   Fill in at least one LLM provider key below
#   docker compose up -d
#
# This file is gitignored — your secrets stay local.
# config.json references these as ${VAR} and is safe to commit.
#
# ══════════════════════════════════════════════════════════

# ── LLM Providers (set at least one) ──

# Anthropic — standard API key (usage-based billing)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Anthropic — OAuth token (uses Claude Pro/Max subscription)
# Get it with: claude setup-token
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Ollama — local models, no API key needed
# Default: http://localhost:11434 (or http://host.docker.internal:11434 in Docker)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.3

# ── Channels ──

# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# ── Tools ──

# Brave Search API key (enables web_search tool)
# Get one at: https://brave.com/search/api/
# BRAVE_API_KEY=BSA...

# ── Gateway ──

# Authentication token for Web UI + API access
# If empty, the gateway is open (not recommended for public networks)
# AGW_TOKEN=choose-a-strong-token-here

# Port override (default: 18181)
# AGW_PORT=18181

# Log level (debug, info, warn, error)
# LOG_LEVEL=info
