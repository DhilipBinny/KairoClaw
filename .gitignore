# ══════════════════════════════════════════════
# Kairo — .gitignore
# ══════════════════════════════════════════════

# ── Secrets (never commit) ──
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.json
secrets.enc
master.key
.gh-token

# ── Local reference (untracked, kept on disk) ──
_local/
docs/_local_reference/

# ── Runtime data (app-managed) ──
agw-data/
local_data/
docker-compose.dev.yml
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.log

agw-data-new/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.log

# ── Dependencies ──
node_modules/
bun.lock
bun.lockb

# ── Build artifacts ──
dist/
build/
coverage/
.tsbuildinfo

# ── OS files ──
.DS_Store
Thumbs.db

# ── Claude Code ──
.claude/

# ── Editor / IDE ──
.vscode/
.idea/
*.swp
*~

# ── Docker ──
docker-compose.override.yml
